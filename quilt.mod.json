{
  "schema_version": 1,
  "quilt_loader": {
    "group": "org.classicscraftworks",
    "id": "extract-enchants",
    "version": "0.3.0",
    "metadata": {
      "name": "Extract Enchants",
      "description": "Extract enchantments from tools, weapons and armour on to Enchanted Books via crafting, at the cost of destroying the original item.",
      "contributors": {
        "Classic36": "Developer"
      },
      "contact": {
        "homepage": "https://modrinth.com/datapack/extract-enchants",
        "sources": "https://github.com/Classics-Craftworks/Extract-Enchants",
        "issues": "https://github.com/Classics-Craftworks/Extract-Enchants/issues"
      },
      "icon": "pack.png"
    },
    "intermediate_mappings": "net.fabricmc:intermediary",
    "depends": [
      {
        "id": "quilt_resource_loader",
        "versions": "*",
        "unless": "fabric-resource-loader-v1"
      },
      {
        "id": "minecraft",
        "versions": ">=26.1 <26.3"
      }
    ]
  }
}